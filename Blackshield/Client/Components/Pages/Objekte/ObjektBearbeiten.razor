@page "/objekte/bearbeiten/{Id}"
@using System.Globalization
@using Domain.Data.Entities
@using Domain.Data.Enums
@using Domain.Extensions
@using Domain.Services
@using Domain.Viewmodels
@using Newtonsoft.Json

<PageTitle>Neues Objekt · Blackshield</PageTitle>

<MudStack Spacing="5">
<NavigationLock OnBeforeInternalNavigation="OnBeforeNavigation" ConfirmExternalNavigation="IsDirty"></NavigationLock>
<MudBreadcrumbs Items="breadcrumbs" Class="pa-0" Separator=">"/>

<MudStack Spacing="1">
    <MudText Typo="Typo.h4" Class="blackshield-page-title">Objekt bearbeiten</MudText>
    <MudText Typo="Typo.body1" Color="Color.Tertiary">
        Bearbeite ein Mietobjekt und passe die Eckdaten an.
    </MudText>
</MudStack>
@if (Viewmodel is null)
{
    <MudStack AlignItems="AlignItems.Center" Class="pa-8">
        <MudProgressCircular Indeterminate="true"
                             Color="Color.Primary"
                             Size="Size.Large"/>
        <MudText Typo="Typo.body2" Color="Color.Tertiary">Lade Objekt…</MudText>
    </MudStack>
}
else
{
    <MudGrid Spacing="4">
    <MudItem xs="12" md="8">
        <MudPaper Elevation="0" Outlined="true" Class="pa-5" Style="border-radius: 16px;">
            <MudStack Spacing="5">
                <div>
                    <MudText Typo="Typo.h6" Class="mb-3">Eckdaten</MudText>
                    <MudGrid Spacing="3">
                        <MudItem xs="12">
                            <MudTextField T="string" Label="Bezeichnung"
                                          @bind-Value="Viewmodel.BezeichnungWirtschaftseinheit"
                                          Variant="Variant.Outlined" Margin="Margin.Dense"
                                          Placeholder="z. B. Appartmentkomplex Hamburg Mitte"/>
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField T="string" Label="Bezeichnung Nutzungseinheit"
                                          @bind-Value="Viewmodel.BezeichnungNutzungseinheit"
                                          Variant="Variant.Outlined" Margin="Margin.Dense"
                                          Placeholder="z. B. 3-Zimmer Altbau · St.Pauli"/>
                        </MudItem>
                        <MudItem xs="12" md="8">
                            <MudTextField T="string" Label="Straße" @bind-Value="Viewmodel.Straße"
                                          Variant="Variant.Outlined" Margin="Margin.Dense"/>
                        </MudItem>
                        <MudItem xs="6" md="2">
                            <MudTextField T="string" Label="HausNr." @bind-Value="Viewmodel.Hausnummer"
                                          Variant="Variant.Outlined" Margin="Margin.Dense"/>
                        </MudItem>
                        <MudItem xs="6" md="2">
                            <MudTextField T="string" Label="PLZ" @bind-Value="Viewmodel.PLZ"
                                          Variant="Variant.Outlined" Margin="Margin.Dense"/>
                        </MudItem>
                        <MudItem xs="6" md="2">
                            <MudTextField T="string" Label="Ort" @bind-Value="Viewmodel.Ort"
                                          Variant="Variant.Outlined" Margin="Margin.Dense"/>
                        </MudItem>
                    </MudGrid>
                </div>

                <div>
                    <MudText Typo="Typo.h6" Class="mb-3">Objektdaten</MudText>
                    <MudGrid Spacing="3">
                        <MudItem xs="6" md="3">
                            <MudNumericField T="int" Label="Zimmer" @bind-Value="Viewmodel.AnzahlZimmer"
                                             Variant="Variant.Outlined" Margin="Margin.Dense" Min="1"/>
                        </MudItem>
                        <MudItem xs="6" md="3">
                            <MudNumericField T="decimal" Label="Wohnfläche (m²)"
                                             @bind-Value="Viewmodel.Wohnfläche" Variant="Variant.Outlined"
                                             Margin="Margin.Dense" Min="1"/>
                        </MudItem>
                        <MudItem xs="6" md="3">
                            <MudTextField T="string" Label="Etage" @bind-Value="Viewmodel.Etage"
                                          Variant="Variant.Outlined" Margin="Margin.Dense"/>
                        </MudItem>
                        <MudItem xs="6" md="3">
                            <MudSelect T="Wohnungstyp" Label="Typ" @bind-Value="Viewmodel.Typ"
                                       Variant="Variant.Outlined" Margin="Margin.Dense">
                                <MudSelectItem
                                    Value="@(Wohnungstyp.Wohnung)">
                                    @Wohnungstyp.Wohnung.ToString()
                                </MudSelectItem>
                                <MudSelectItem
                                    Value="@(Wohnungstyp.Haus)">
                                    @Wohnungstyp.Haus.ToString()
                                </MudSelectItem>
                                @* <MudSelectItem Value="@("Apartment")">Apartment</MudSelectItem> *@
                                @* <MudSelectItem Value="@("Loft")">Loft</MudSelectItem> *@
                            </MudSelect>
                        </MudItem>
                    </MudGrid>
                </div>

                <div>
                    <MudText Typo="Typo.h6" Class="mb-3">Konditionen</MudText>
                    <MudGrid Spacing="3">
                        <MudItem xs="6" md="3">
                            <MudNumericField T="decimal" Label="Kaltmiete (€)"
                                             Culture="@CultureInfo.InvariantCulture"
                                             @bind-Value="Viewmodel.Kaltmiete" Variant="Variant.Outlined"
                                             Margin="Margin.Dense"/>
                        </MudItem>
                        <MudItem xs="6" md="3">
                            <MudNumericField T="decimal" Label="Nebenkosten (€)"
                                             Culture="@CultureInfo.InvariantCulture"
                                             @bind-Value="Viewmodel.Nebenkosten" Variant="Variant.Outlined"
                                             Margin="Margin.Dense"/>
                        </MudItem>
                        <MudItem xs="6" md="3">
                            <MudNumericField T="decimal" Label="Heizkosten (€)"
                                             Culture="@CultureInfo.InvariantCulture"
                                             @bind-Value="Viewmodel.Heizkosten" Variant="Variant.Outlined"
                                             Margin="Margin.Dense"/>
                        </MudItem>
                        <MudItem xs="6" md="3">
                            <MudNumericField T="decimal" Label="Kaution (€)"
                                             Culture="@CultureInfo.InvariantCulture"
                                             @bind-Value="Viewmodel.Kaution" Variant="Variant.Outlined"
                                             Margin="Margin.Dense"/>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudDatePicker Label="Frühester Einzug" @bind-Value="Viewmodel.FrühesterEinzugAb"
                                           Variant="Variant.Outlined" Margin="Margin.Dense"/>
                        </MudItem>
                    </MudGrid>
                </div>

                <div>
                    <MudText Typo="Typo.h6" Class="mb-3">Beschreibung</MudText>
                    <MudTextField T="string"
                                  Label="Beschreibungstext"
                                  @bind-Value="Viewmodel.Beschreibung"
                                  Lines="6"
                                  Variant="Variant.Outlined"
                                  Placeholder="Charmante Wohnung mit … "/>
                </div>

                <div>
                    <MudText Typo="Typo.h6" Class="mb-3">Bilder &amp; Dokumente</MudText>
                    <MudPaper Outlined="true" Class="pa-6 blackshield-empty-state"
                              Style="border-radius: 12px; text-align: center;">
                        <MudIcon Icon="@Icons.Material.Outlined.CloudUpload" Size="Size.Large"
                                 Color="Color.Tertiary"/>
                        <MudText Typo="Typo.body2" Class="mt-2">
                            Dateien hierher ziehen oder klicken zum
                            Auswählen
                        </MudText>
                        <MudText Typo="Typo.caption" Color="Color.Tertiary">
                            JPG, PNG, PDF · max. 25 MB pro
                            Datei
                        </MudText>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Class="mt-3"
                                   StartIcon="@Icons.Material.Filled.Add">
                            Dateien auswählen
                        </MudButton>
                    </MudPaper>
                </div>
            </MudStack>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="4">
        <MudPaper Elevation="0" Outlined="true" Class="pa-5 sticky-side" Style="border-radius: 16px;">
            <MudStack Spacing="3">
                <MudText Typo="Typo.h6">Veröffentlichung</MudText>
                <MudRadioGroup T="string" Value="@visibility"
                               ValueChanged="@((string v) => visibility = v)">
                    <MudRadio T="string" Value="@("entwurf")" Color="Color.Primary">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body2" Style="font-weight: 600;">
                                Als Entwurf speichern
                            </MudText>
                            <MudText Typo="Typo.caption" Color="Color.Tertiary">
                                Nicht öffentlich
                                sichtbar
                            </MudText>
                        </MudStack>
                    </MudRadio>
                    <MudRadio T="string" Value="@("intern")" Color="Color.Primary">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body2" Style="font-weight: 600;">
                                Nur via Einladung
                            </MudText>
                            <MudText Typo="Typo.caption" Color="Color.Tertiary">
                                Interessenten erhalten
                                persönlichen Link
                            </MudText>
                        </MudStack>
                    </MudRadio>
                    <MudRadio T="string" Value="@("oeffentlich")" Color="Color.Primary">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body2" Style="font-weight: 600;">Öffentlich</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Tertiary">
                                Auch auf gekoppelten
                                Portalen sichtbar
                            </MudText>
                        </MudStack>
                    </MudRadio>
                </MudRadioGroup>

                <MudDivider/>

                <MudText Typo="Typo.h6">Vorgaben für Interessenten</MudText>
                <MudSwitch T="bool" Color="Color.Primary" Label="Selbstauskunft Pflicht"/>
                <MudSwitch T="bool" Color="Color.Primary" Label="Bonitätsnachweis anfordern"/>
                <MudSwitch T="bool" Color="Color.Primary" Label="Mieterselbstauskunft + DSGVO"/>

                <MudDivider/>

                <MudStack Spacing="2">
                    <MudButton Variant="Variant.Filled" OnClick="SaveObjektAsync" Color="Color.Primary"
                               FullWidth="true" Size="Size.Large" StartIcon="@Icons.Material.Filled.Save">
                        Objekt speichern
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" FullWidth="true"
                               Href="/objekte">
                        Abbrechen
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>
    </MudItem>
    </MudGrid>
}
</MudStack>
@attribute [StreamRendering]
@inject WohnobjektService     Service;
@inject ISnackbar             Snackbar
@inject NavigationManager     Navigation;
@inject IDialogService        DialogService

@code {

    [Parameter]
    public required string Id { get; set; }

    private          string               visibility  = "intern";
    private readonly List<BreadcrumbItem> breadcrumbs = [new BreadcrumbItem("Objekte", "/objekte")];

    public WohnobjektViewmodel? Viewmodel  { get; set; }
    public string               CleanState { get; set; } = string.Empty;

    public bool IsDirty => Viewmodel is not null &&
                           JsonConvert.SerializeObject(Viewmodel) != CleanState;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var nutzungseinheitId = Guid.Parse(Id);
            var nutzungseinheit   = await Service.LoadNutzungseinheitByIdAsync(nutzungseinheitId);

            InitBreadcrumbs(nutzungseinheit);

            Viewmodel  = nutzungseinheit!.ToViewmodel();
            CleanState = JsonConvert.SerializeObject(Viewmodel);
        }
        catch (Exception e)
        {
            RaiseErrorToast(e.Message);
        }
    }

    private void InitBreadcrumbs(Nutzungseinheit? nutzungseinheit)
    {
        breadcrumbs.Add(new BreadcrumbItem(nutzungseinheit?.GetFullAddress() ?? "N/A", $"/objekte/{Id}"));
        breadcrumbs.Add(new BreadcrumbItem("Bearbeitung", null, true));
    }

    private void RaiseErrorToast(string message)
    {
        ArrangeSnackbar();
        Snackbar.Add(message, Severity.Error);
    }

    private void ArrangeSnackbar()
    {
        Snackbar.Clear();
        Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomCenter;
    }

    private void RaiseSuccessToast(string message)
    {
        ArrangeSnackbar();

        Snackbar.Add(message, Severity.Success);
    }

    private async Task SaveObjektAsync()
    {
        try
        {
            await Service.UpdateWohnobjectAsync(Viewmodel!);

            RaiseSuccessToast("Objekt erfolgreich bearbeitet.");

            CleanState = JsonConvert.SerializeObject(Viewmodel);

            Navigation.NavigateTo($"/objekte/{Id}");
        }
        catch (Exception e)
        {
            RaiseErrorToast(e.Message);
        }
    }

    private async Task OnBeforeNavigation(LocationChangingContext context)
    {
        if(!IsDirty)
            return;

        var contextVerlassen = await DialogService.ShowMessageBoxAsync(title: "Ungespeicherte Änderungen",
                                                                       message: "Du hast Änderungen, die noch nicht gespeichert wurden. Seite wirklich verlassen?",
                                                                       yesText: "Verlassen",
                                                                       cancelText: "Abbrechen");

        if(contextVerlassen is null || !contextVerlassen.Value)
            context.PreventNavigation();
    }

}