@page "/objekte"
@using Domain.Data.Entities
@using Domain.Services

<PageTitle>Objekte · Blackshield</PageTitle>

<MudStack Spacing="6">

    <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween" Class="flex-wrap">
        <MudStack Spacing="1">
            <MudText Typo="Typo.h4" Class="blackshield-page-title">Objekte</MudText>
            <MudText Typo="Typo.body1" Color="Color.Tertiary">12 aktive · 3 in Vorbereitung · 5 archiviert</MudText>
        </MudStack>
        <MudStack Row="true" Spacing="2">
            <MudButton StartIcon="@Icons.Material.Outlined.Download"
                       Variant="Variant.Outlined"
                       Color="Color.Default">
                Export
            </MudButton>
            <MudButton StartIcon="@Icons.Material.Filled.Add"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       Href="/objekte/neu">
                Neues Objekt
            </MudButton>
        </MudStack>
    </MudStack>

    <MudPaper Elevation="0" Outlined="true" Class="pa-4" Style="border-radius: 16px;">
        <MudGrid Spacing="3" Justify="Justify.FlexStart">
            <MudItem xs="12" md="5">
                <MudTextField T="string"
                              Placeholder="Adresse, Bezeichnung, PLZ…"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"/>
            </MudItem>
            <MudItem xs="6" md="2">
                <MudSelect T="string" Placeholder="Status" Variant="Variant.Outlined" Margin="Margin.Dense">
                    <MudSelectItem Value="@("Alle")">Alle</MudSelectItem>
                    <MudSelectItem Value="@("Aktiv")">Aktiv</MudSelectItem>
                    <MudSelectItem Value="@("Vorbereitung")">In Vorbereitung</MudSelectItem>
                    <MudSelectItem Value="@("Archiviert")">Archiviert</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="6" md="2">
                <MudSelect T="string" Placeholder="Stadt" Variant="Variant.Outlined" Margin="Margin.Dense">
                    <MudSelectItem Value="@("Alle")">Alle Städte</MudSelectItem>
                    <MudSelectItem Value="@("Berlin")">Berlin</MudSelectItem>
                    <MudSelectItem Value="@("Hamburg")">Hamburg</MudSelectItem>
                    <MudSelectItem Value="@("Köln")">Köln</MudSelectItem>
                    <MudSelectItem Value="@("München")">München</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="6" md="2">
                <MudSelect T="string" Placeholder="Zimmer" Variant="Variant.Outlined" Margin="Margin.Dense">
                    <MudSelectItem Value="@("Egal")">Egal</MudSelectItem>
                    <MudSelectItem Value="@("1")">1 Zimmer</MudSelectItem>
                    <MudSelectItem Value="@("2")">2 Zimmer</MudSelectItem>
                    <MudSelectItem Value="@("3")">3+ Zimmer</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="6" md="1" Class="d-flex align-center">
                <MudToggleIconButton Toggled="@gridView"
                                     ToggledChanged="@(v => gridView = v)"
                                     Icon="@Icons.Material.Filled.GridView"
                                     ToggledIcon="@Icons.Material.Filled.ViewList"
                                     Color="Color.Default"
                                     ToggledColor="Color.Primary"/>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @if (gridView)
    {
        <MudGrid Spacing="4">
            @foreach (var nutzungseinheit in Nutzungseinheiten)
            {
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <MudPaper Elevation="1" Class="blackshield-property-card" Style="border-radius: 16px; cursor: pointer;" @onclick="@(() => GoToDetail(nutzungseinheit.Id))">
                        <div class="property-image" style="@("background-image: linear-gradient(135deg, #8B5CF6 0%, #A78BFA 100%);")">
                            <MudChip T="string"
                                     Class="status-chip"
                                     Size="Size.Small"
                                     Color="@Color.Info"
                                     Variant="Variant.Filled">
                                @nutzungseinheit.Status
                            </MudChip>
                            <div style="position: absolute; bottom: 12px; right: 12px;">
                                <MudIconButton Icon="@Icons.Material.Filled.MoreHoriz"
                                               Color="Color.Inherit"
                                               Style="background: rgba(255,255,255,0.85); color: #0F172A;"
                                               Size="Size.Small"/>
                            </div>
                        </div>
                        <div class="pa-4">
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">@nutzungseinheit.Bezeichnung</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Tertiary">@nutzungseinheit.Etage?.Wirtschaftseinheit?.Straße</MudText>
                            </MudStack>

                            <MudStack Row="true" Spacing="3" Class="mt-3 mb-3">
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                    <MudIcon Icon="@Icons.Material.Outlined.SquareFoot" Size="Size.Small" Color="Color.Tertiary"/>
                                    <MudText Typo="Typo.caption">@nutzungseinheit.Wohnfläche m²</MudText>
                                </MudStack>
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                    <MudIcon Icon="@Icons.Material.Outlined.Bed" Size="Size.Small" Color="Color.Tertiary"/>
                                    <MudText Typo="Typo.caption">@nutzungseinheit.AnzahlZimmer Zi.</MudText>
                                </MudStack>
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                    <MudIcon Icon="@Icons.Material.Outlined.Stairs" Size="Size.Small" Color="Color.Tertiary"/>
                                    <MudText Typo="Typo.caption">@nutzungseinheit.Etage?.Bezeichnung.</MudText>
                                </MudStack>
                            </MudStack>

                            <MudDivider Class="my-2"/>

                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.h6" Style="font-weight: 700; line-height: 1;">@nutzungseinheit.Kaltmiete.Betrag € <span style="font-size: 0.75rem; font-weight: 400; color: var(--mud-palette-text-secondary);">/Mt.</span></MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Tertiary">Kaltmiete</MudText>
                                </MudStack>
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                    <MudBadge Content="11" Color="Color.Primary" Origin="Origin.TopRight" Overlap="true">
                                        <MudIcon Icon="@Icons.Material.Outlined.People" Color="Color.Tertiary"/>
                                    </MudBadge>
                                </MudStack>
                            </MudStack>
                        </div>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    }
    else
    {
        <MudPaper Elevation="0" Outlined="true" Style="border-radius: 16px; overflow: hidden;">
            <MudTable Items="Nutzungseinheiten" Hover="true" Dense="false" Bordered="false" Striped="false" Elevation="0">
                <HeaderContent>
                    <MudTh>Bezeichnung</MudTh>
                    <MudTh>Adresse</MudTh>
                    <MudTh>Zimmer / Fläche</MudTh>
                    <MudTh>Miete</MudTh>
                    <MudTh>Interessenten</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate Context="row">
                    <MudTd DataLabel="Bezeichnung">
                        <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Center">
                            <div class="property-thumb" style="@($"background: linear-gradient(135deg, #8B5CF6, #A78BFA);")"></div>
                            <MudText Typo="Typo.body2" Style="font-weight: 600;">@row.Bezeichnung</MudText>
                        </MudStack>
                    </MudTd>
                    <MudTd DataLabel="Adresse">@row.GetFullAddress()</MudTd>
                    <MudTd DataLabel="Zimmer / Fläche">@row.AnzahlZimmer Zi. · @row.Wohnfläche m²</MudTd>
                    <MudTd DataLabel="Miete">@row.Kaltmiete €</MudTd>
                    <MudTd DataLabel="Interessenten">
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Primary">12</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string" Size="Size.Small" Color="@Color.Info" Variant="Variant.Filled">@row.Status</MudChip>
                    </MudTd>
                    <MudTd>
                        <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" Color="Color.Default" OnClick="@(() => GoToDetail(row.Id))"/>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }
</MudStack>

@inject NavigationManager     Nav
@inject WohnobjektService     Service;

@code {
    private bool              gridView = true;
    public  Nutzungseinheit[] Nutzungseinheiten { get; set; } = [];

    protected override async Task OnInitializedAsync()
    {
        Nutzungseinheiten = Service.LoadAllNutzungseinheiten();

        await base.OnInitializedAsync();
    }

    private void GoToDetail(Guid id) => Nav.NavigateTo($"/objekte/{id}");
}