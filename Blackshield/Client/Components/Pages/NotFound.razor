@page "/not-found"
@layout MainLayout

<PageTitle>Seite nicht gefunden · Blackshield</PageTitle>

<MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="4" Style="min-height: 60vh; text-align: center;">
    <div class="not-found-illustration">
        <MudIcon Icon="@Icons.Material.Outlined.TravelExplore" Size="Size.Large" Style="font-size: 96px; color: var(--mud-palette-primary);"/>
    </div>
    <MudStack Spacing="1" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h3" Class="blackshield-page-title">404 · Seite nicht gefunden</MudText>
        <MudText Typo="Typo.body1" Color="Color.Tertiary" Style="max-width: 480px;">
            Die Seite, die du suchst, existiert nicht oder wurde verschoben.
            Über die Navigation kommst du sicher wieder ans Ziel.
        </MudText>
    </MudStack>
    <MudStack Row="true" Spacing="2">
        <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Nav.NavigateTo("/"))">
            Zurück zum Dashboard
        </MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Search">
            Hilfe durchsuchen
        </MudButton>
    </MudStack>
</MudStack>

@code {
    [Inject] private NavigationManager Nav { get; set; } = default!;
}
