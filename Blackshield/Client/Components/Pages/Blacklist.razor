@page "/blacklist"

<PageTitle>Blacklist · Blackshield</PageTitle>

<MudStack Spacing="6">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start" Class="flex-wrap">
        <MudStack Spacing="1">
            <MudText Typo="Typo.h4" Class="blackshield-page-title">Blacklist</MudText>
            <MudText Typo="Typo.body1" Color="Color.Tertiary">Verwalte gesperrte Interessenten. Einträge sind nur innerhalb deiner Organisation sichtbar.</MudText>
        </MudStack>
        <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Error">Eintrag hinzufügen</MudButton>
    </MudStack>

    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Icon="@Icons.Material.Outlined.Info">
        <strong>Hinweis:</strong> Blacklist-Einträge müssen DSGVO-konform begründet werden. Personenbezogene Daten werden nach 24 Monaten automatisch gelöscht.
    </MudAlert>

    <MudPaper Elevation="0" Outlined="true" Style="border-radius: 16px;">
        <MudTable Items="Entries" Hover="true" Elevation="0">
            <ToolBarContent>
                <MudTextField T="string"
                              Placeholder="Suchen…"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Style="min-width: 280px;"/>
            </ToolBarContent>
            <HeaderContent>
                <MudTh>Person</MudTh>
                <MudTh>Grund</MudTh>
                <MudTh>Gesperrt am</MudTh>
                <MudTh>Gesperrt von</MudTh>
                <MudTh>Aktiv bis</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate Context="row">
                <MudTd>
                    <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Center">
                        <MudAvatar Color="Color.Error" Size="Size.Small">@row.Initials</MudAvatar>
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body2" Style="font-weight: 600;">@row.Name</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Tertiary">@row.Email</MudText>
                        </MudStack>
                    </MudStack>
                </MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Text">@row.Reason</MudChip>
                </MudTd>
                <MudTd>@row.BlockedOn</MudTd>
                <MudTd>@row.BlockedBy</MudTd>
                <MudTd>@row.ValidUntil</MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small"/>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>
</MudStack>

@code {
    private record BlacklistEntry(string Name, string Initials, string Email, string Reason, string BlockedOn, string BlockedBy, string ValidUntil);

    private static readonly BlacklistEntry[] Entries =
    {
