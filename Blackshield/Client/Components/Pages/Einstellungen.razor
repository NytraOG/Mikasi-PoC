@page "/einstellungen"
@page "/einstellungen/{Section}"

<PageTitle>Einstellungen · Blackshield</PageTitle>

<MudStack Spacing="6">
    <MudStack Spacing="1">
        <MudText Typo="Typo.h4" Class="blackshield-page-title">Einstellungen</MudText>
        <MudText Typo="Typo.body1" Color="Color.Tertiary">Konto, Organisation, Benachrichtigungen und Sicherheit.</MudText>
    </MudStack>

    <MudGrid Spacing="4">
        <MudItem xs="12" md="3">
            <MudPaper Elevation="0" Outlined="true" Style="border-radius: 16px; overflow: hidden;">
                <MudNavMenu Rounded="true" Bordered="false" Class="pa-2">
                    <MudNavLink Href="/einstellungen/profil" Icon="@Icons.Material.Outlined.Person">Profil</MudNavLink>
                    <MudNavLink Href="/einstellungen/organisation" Icon="@Icons.Material.Outlined.Business">Organisation</MudNavLink>
                    <MudNavLink Href="/einstellungen/team" Icon="@Icons.Material.Outlined.Groups">Team</MudNavLink>
                    <MudNavLink Href="/einstellungen/benachrichtigungen" Icon="@Icons.Material.Outlined.Notifications">Benachrichtigungen</MudNavLink>
                    <MudNavLink Href="/einstellungen/sicherheit" Icon="@Icons.Material.Outlined.Lock">Sicherheit</MudNavLink>
                    <MudNavLink Href="/einstellungen/integrationen" Icon="@Icons.Material.Outlined.Extension">Integrationen</MudNavLink>
                    <MudNavLink Href="/einstellungen/branding" Icon="@Icons.Material.Outlined.Palette">Branding</MudNavLink>
                    <MudNavLink Href="/einstellungen/api" Icon="@Icons.Material.Outlined.Code">API &amp; Webhooks</MudNavLink>
                </MudNavMenu>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="9">
            <MudPaper Elevation="0" Outlined="true" Class="pa-6" Style="border-radius: 16px;">
                <MudStack Spacing="5">

                    <div>
                        <MudText Typo="Typo.h6" Class="mb-1">Profil</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Tertiary">Diese Daten sind nur intern sichtbar.</MudText>
                    </div>

                    <MudStack Row="true" Spacing="4" AlignItems="AlignItems.Center" Class="flex-wrap">
                        <MudAvatar Size="Size.Large" Style="width: 80px; height: 80px;" Color="Color.Primary">AM</MudAvatar>
                        <MudStack Spacing="1">
                            <MudButton StartIcon="@Icons.Material.Outlined.PhotoCamera" Variant="Variant.Outlined" Color="Color.Default">Bild ändern</MudButton>
                            <MudText Typo="Typo.caption" Color="Color.Tertiary">JPG/PNG · min. 256×256 · max. 2 MB</MudText>
                        </MudStack>
                    </MudStack>

                    <MudDivider/>

                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="6">
                            <MudTextField T="string" Label="Vorname" Variant="Variant.Outlined" Margin="Margin.Dense" Value="@("Anna")"/>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField T="string" Label="Nachname" Variant="Variant.Outlined" Margin="Margin.Dense" Value="@("Müller")"/>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField T="string" Label="E-Mail" Variant="Variant.Outlined" Margin="Margin.Dense" Value="@("anna@blackshield.de")" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.CheckCircle" AdornmentColor="Color.Success"/>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField T="string" Label="Telefon" Variant="Variant.Outlined" Margin="Margin.Dense" Value="@("+49 30 99887766")"/>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudSelect T="string" Label="Sprache" Variant="Variant.Outlined" Margin="Margin.Dense" Value="@("de")">
                                <MudSelectItem Value="@("de")">Deutsch</MudSelectItem>
                                <MudSelectItem Value="@("en")">English</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudSelect T="string" Label="Zeitzone" Variant="Variant.Outlined" Margin="Margin.Dense" Value="@("Europe/Berlin")">
                                <MudSelectItem Value="@("Europe/Berlin")">Europe/Berlin (UTC+1)</MudSelectItem>
                                <MudSelectItem Value="@("Europe/Vienna")">Europe/Vienna (UTC+1)</MudSelectItem>
                                <MudSelectItem Value="@("Europe/Zurich")">Europe/Zurich (UTC+1)</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                    </MudGrid>

                    <MudDivider/>

                    <div>
                        <MudText Typo="Typo.h6" Class="mb-1">Verbundene Konten</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Tertiary" Class="mb-3">Login &amp; SSO über externe Anbieter.</MudText>
                        <MudStack Spacing="2">
                            <MudPaper Outlined="true" Class="pa-3" Style="border-radius: 10px;">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                    <MudIcon Icon="@Icons.Custom.Brands.Google" Style="color: #EA4335;"/>
                                    <MudStack Spacing="0" Style="flex: 1;">
                                        <MudText Typo="Typo.body2" Style="font-weight: 600;">Google</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Tertiary">anna@blackshield.de</MudText>
                                    </MudStack>
                                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text">Verbunden</MudChip>
                                    <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small">Trennen</MudButton>
                                </MudStack>
                            </MudPaper>
                            <MudPaper Outlined="true" Class="pa-3" Style="border-radius: 10px;">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                    <MudIcon Icon="@Icons.Custom.Brands.Apple"/>
                                    <MudStack Spacing="0" Style="flex: 1;">
                                        <MudText Typo="Typo.body2" Style="font-weight: 600;">Apple</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Tertiary">Nicht verbunden</MudText>
                                    </MudStack>
                                    <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small">Verbinden</MudButton>
                                </MudStack>
                            </MudPaper>
                        </MudStack>
                    </div>

                    <MudDivider/>

                    <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd">
                        <MudButton Variant="Variant.Text" Color="Color.Default">Abbrechen</MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save">Änderungen speichern</MudButton>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudStack>

@code {
    [Parameter] public string? Section { get; set; }
}
