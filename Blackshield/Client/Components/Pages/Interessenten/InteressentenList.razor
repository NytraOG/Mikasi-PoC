@page "/interessenten"

<PageTitle>Interessenten · Blackshield</PageTitle>

<MudStack Spacing="6">

    <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween" Class="flex-wrap">
        <MudStack Spacing="1">
            <MudText Typo="Typo.h4" Class="blackshield-page-title">Interessenten</MudText>
            <MudText Typo="Typo.body1" Color="Color.Tertiary">147 insgesamt · 12 neue diese Woche</MudText>
        </MudStack>
        <MudStack Row="true" Spacing="2">
            <MudButton StartIcon="@Icons.Material.Outlined.MailOutline"
                       Variant="Variant.Outlined"
                       Color="Color.Default">
                Sammel-E-Mail
            </MudButton>
            <MudButton StartIcon="@Icons.Material.Filled.PersonAdd"
                       Variant="Variant.Filled"
                       Color="Color.Primary">
                Interessent einladen
            </MudButton>
        </MudStack>
    </MudStack>

    <MudGrid Spacing="4">
        @foreach (var k in Kpis)
        {
            <MudItem xs="6" md="3">
                <MudPaper Elevation="0" Outlined="true" Class="pa-4" Style="border-radius: 14px;">
                    <MudStack Spacing="1">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <div class="mini-icon" style="@($"background:{k.Bg};")">
                                <MudIcon Icon="@k.Icon" Size="Size.Small" Style="@($"color:{k.IconColor};")"/>
                            </div>
                            <MudText Typo="Typo.caption" Color="Color.Tertiary">@k.Label</MudText>
                        </MudStack>
                        <MudText Typo="Typo.h5" Style="font-weight: 700; line-height: 1.1;">@k.Value</MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>

    <MudPaper Elevation="0" Outlined="true" Style="border-radius: 16px; overflow: hidden;">

        <MudTabs Rounded="false" Border="false" Elevation="0" Class="pt-2 px-3" SliderColor="Color.Primary">
            <MudTabPanel Text="Alle"/>
            <MudTabPanel Text="Neu" BadgeData="12" BadgeColor="Color.Primary"/>
            <MudTabPanel Text="In Prüfung" BadgeData="8" BadgeColor="Color.Info"/>
            <MudTabPanel Text="Eingeladen"/>
            <MudTabPanel Text="Abgesagt"/>
            <MudTabPanel Text="Blacklist"/>
        </MudTabs>

        <MudDivider/>

        <div class="pa-4">
            <MudStack Row="true" Spacing="2" Class="flex-wrap">
                <MudTextField T="string"
                              Placeholder="Name, E-Mail, Adresse…"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Style="min-width: 280px;"/>
                <MudSelect T="string" Placeholder="Objekt" Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width: 200px;">
                    <MudSelectItem Value="@("Alle")">Alle Objekte</MudSelectItem>
                    <MudSelectItem Value="@("p1")">Sonnenallee 142</MudSelectItem>
                    <MudSelectItem Value="@("p2")">Hohenzollernring 8</MudSelectItem>
                </MudSelect>
                <MudSelect T="string" Placeholder="Score" Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width: 160px;">
                    <MudSelectItem Value="@("alle")">Alle Scores</MudSelectItem>
                    <MudSelectItem Value="@("75")">Top-Match (≥75)</MudSelectItem>
                    <MudSelectItem Value="@("50")">Wartet (50-74)</MudSelectItem>
                </MudSelect>
                <MudSpacer/>
                <MudButton StartIcon="@Icons.Material.Outlined.Tune" Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small">
                    Weitere Filter
                </MudButton>
            </MudStack>
        </div>

        <MudDivider/>

        <MudTable T="Prospect" Items="Prospects" Hover="true" Elevation="0" Striped="false" RowsPerPage="10">
            <HeaderContent>
                <MudTh><MudCheckBox T="bool" Color="Color.Primary"/></MudTh>
                <MudTh>Name</MudTh>
                <MudTh>Objekt</MudTh>
                <MudTh>Eingang</MudTh>
                <MudTh>Selbstauskunft</MudTh>
                <MudTh>Score</MudTh>
                <MudTh>Status</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate Context="row">
                <MudTd><MudCheckBox T="bool" Color="Color.Primary"/></MudTd>
                <MudTd DataLabel="Name">
                    <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Center">
                        <MudAvatar Color="@row.AvatarColor" Size="Size.Small">@row.Initials</MudAvatar>
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body2" Style="font-weight: 600;">@row.Name</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Tertiary">@row.Email</MudText>
                        </MudStack>
                    </MudStack>
                </MudTd>
                <MudTd DataLabel="Objekt">
                    <MudText Typo="Typo.body2">@row.PropertyName</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Tertiary">@row.PropertyAddress</MudText>
                </MudTd>
                <MudTd DataLabel="Eingang">
                    <MudText Typo="Typo.body2">@row.Received</MudText>
                </MudTd>
                <MudTd DataLabel="Selbstauskunft">
                    @if (row.SelfDisclosure == "Eingereicht")
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text" Icon="@Icons.Material.Filled.CheckCircle">Eingereicht</MudChip>
                    }
                    else if (row.SelfDisclosure == "Offen")
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Text" Icon="@Icons.Material.Filled.Schedule">Offen</MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text">—</MudChip>
                    }
                </MudTd>
                <MudTd DataLabel="Score">
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                        <MudProgressLinear Value="@row.Score" Color="@(row.Score >= 75 ? Color.Success : row.Score >= 50 ? Color.Warning : Color.Error)" Style="width: 80px; height: 6px; border-radius: 3px;"/>
                        <MudText Typo="Typo.caption">@row.Score %</MudText>
                    </MudStack>
                </MudTd>
                <MudTd DataLabel="Status">
                    <MudChip T="string" Size="Size.Small" Color="@row.StatusColor" Variant="Variant.Filled">@row.Status</MudChip>
                </MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" OnClick="@(() => OpenDetail(row))"/>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="@(new int[]{ 10, 25, 50 })"/>
            </PagerContent>
        </MudTable>
    </MudPaper>
</MudStack>

<MudDrawer @bind-Open="@drawerOpen" Anchor="Anchor.End" Width="480px" Elevation="6" Variant="DrawerVariant.Temporary">
    @if (Selected is not null)
    {
        <div class="pa-5">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
                <MudText Typo="Typo.h6">Interessent</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="@(() => drawerOpen = false)"/>
            </MudStack>

            <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Center" Class="mb-4">
                <MudAvatar Color="@Selected.AvatarColor" Size="Size.Large">@Selected.Initials</MudAvatar>
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h6">@Selected.Name</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Tertiary">@Selected.Email</MudText>
                </MudStack>
            </MudStack>

            <MudPaper Outlined="true" Class="pa-4 mb-4" Style="border-radius: 12px;">
                <MudStack Spacing="2">
                    <KvRow Label="Objekt" Value="@Selected.PropertyName"/>
                    <KvRow Label="Eingang" Value="@Selected.Received"/>
                    <KvRow Label="Score" Value="@($"{Selected.Score} %")" Highlight="true"/>
                    <KvRow Label="Selbstauskunft" Value="@Selected.SelfDisclosure"/>
                    <KvRow Label="Status" Value="@Selected.Status"/>
                </MudStack>
            </MudPaper>

            <MudText Typo="Typo.subtitle2" Class="mb-2">Aktionen</MudText>
            <MudStack Spacing="2">
                <MudButton FullWidth="true" StartIcon="@Icons.Material.Outlined.EventAvailable" Variant="Variant.Outlined" Color="Color.Primary" Style="justify-content: flex-start;">Besichtigung anbieten</MudButton>
                <MudButton FullWidth="true" StartIcon="@Icons.Material.Outlined.MailOutline" Variant="Variant.Outlined" Color="Color.Default" Style="justify-content: flex-start;">E-Mail senden</MudButton>
                <MudButton FullWidth="true" StartIcon="@Icons.Material.Outlined.AssignmentTurnedIn" Variant="Variant.Outlined" Color="Color.Default" Style="justify-content: flex-start;">Selbstauskunft anfordern</MudButton>
                <MudButton FullWidth="true" StartIcon="@Icons.Material.Outlined.Block" Variant="Variant.Outlined" Color="Color.Error" Style="justify-content: flex-start;">Auf Blacklist setzen</MudButton>
            </MudStack>
        </div>
    }
</MudDrawer>

