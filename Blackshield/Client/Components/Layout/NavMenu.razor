@implements IDisposable
@inject NavigationManager NavigationManager

<div class="blackshield-nav-root">
    <div class="blackshield-nav-brand">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <div class="blackshield-nav-brand-mark">
                <MudIcon Icon="@Icons.Material.Filled.Shield" Color="Color.Primary" Size="Size.Medium"/>
            </div>
            <MudStack Spacing="0">
                <MudText Typo="Typo.h6" Class="blackshield-brand" Style="color: var(--mud-palette-text-primary); line-height: 1.1;">Blackshield</MudText>
                <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary); line-height: 1.1;">Vermietungs-Plattform</MudText>
            </MudStack>
        </MudStack>
    </div>

    <MudDivider Class="blackshield-nav-divider"/>

    <MudNavMenu Class="blackshield-nav-menu" Color="Color.Primary" Bordered="false" Rounded="true" Margin="Margin.Dense">

        <div class="blackshield-nav-section-label">Übersicht</div>
        <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Outlined.Dashboard">Dashboard</MudNavLink>

        <div class="blackshield-nav-section-label">Vermietung</div>
        <MudNavLink Href="/objekte" Icon="@Icons.Material.Outlined.Apartment">Objekte</MudNavLink>
        <MudNavLink Href="/interessenten" Icon="@Icons.Material.Outlined.People">Interessenten</MudNavLink>
        <MudNavLink Href="/termine" Icon="@Icons.Material.Outlined.CalendarMonth">Termine</MudNavLink>
        <MudNavLink Href="/unterlagen" Icon="@Icons.Material.Outlined.Description">Unterlagen</MudNavLink>
        <MudNavLink Href="/mietvertraege" Icon="@Icons.Material.Outlined.Gavel">Mietverträge</MudNavLink>

        <div class="blackshield-nav-section-label">Verwaltung</div>
        <MudNavLink Href="/blacklist" Icon="@Icons.Material.Outlined.Block">Blacklist</MudNavLink>
        <MudNavLink Href="/marktdaten" Icon="@Icons.Material.Outlined.TrendingUp">Marktdaten</MudNavLink>

        <div class="blackshield-nav-section-label">Konto</div>
        <MudNavLink Href="/abo" Icon="@Icons.Material.Outlined.CreditCard">Abo &amp; Abrechnung</MudNavLink>
        <MudNavLink Href="/einstellungen" Icon="@Icons.Material.Outlined.Settings">Einstellungen</MudNavLink>
    </MudNavMenu>

    <MudSpacer/>

    <div class="blackshield-nav-footer">
        <MudPaper Elevation="0" Class="blackshield-upsell-card pa-4" Square="false">
            <MudStack Spacing="2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Bolt" Color="Color.Secondary"/>
                    <MudText Typo="Typo.subtitle2" Style="color: var(--mud-palette-text-primary); font-weight: 600;">Upgrade auf Pro+</MudText>
                </MudStack>
                <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">
                    Unbegrenzte Objekte, automatisierte Selbstauskunft &amp; Marktanalysen freischalten.
                </MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Secondary" FullWidth="true" Size="Size.Small" Href="/abo">
                    Jetzt upgraden
                </MudButton>
            </MudStack>
        </MudPaper>
    </div>
</div>

@code {

    protected override void OnInitialized()
    {
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }

}
