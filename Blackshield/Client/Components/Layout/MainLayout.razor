@inherits LayoutComponentBase

<MudThemeProvider Theme="BlackshieldTheme.Instance" IsDarkMode="_isDarkMode"/>
<MudPopoverProvider/>
<MudDialogProvider/>
<MudSnackbarProvider/>

<MudLayout>
    <MudAppBar Elevation="0" Dense="false" Style="background-color: var(--mud-palette-appbar-background); color: var(--mud-palette-appbar-text); border-bottom: 1px solid var(--mud-palette-lines-default);">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="ToggleDrawer"/>

        <MudTextField T="string"
                      Placeholder="Objekte, Interessenten, Adressen suchen…"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Class="ml-3 mr-3 mt-0 blackshield-search"
                      Style="max-width: 460px; flex: 1;"/>

        <MudSpacer/>
        <form method="post" action="/auth/logout">
            <AntiforgeryToken/>
            <button type="submit">Abmelden</button>
        </form>
        <MudTooltip Text="Theme umschalten">
            <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Outlined.LightMode : Icons.Material.Outlined.DarkMode)"
                           Color="Color.Default"
                           OnClick="ToggleTheme"/>
        </MudTooltip>

        <MudTooltip Text="Hilfe &amp; Support">
            <MudIconButton Icon="@Icons.Material.Outlined.HelpOutline"
                           Color="Color.Default"
                           Href="/hilfe"/>
        </MudTooltip>

        <MudTooltip Text="Benachrichtigungen">
            <MudBadge Content="3" Color="Color.Error" Overlap="true" Class="mx-2">
                <MudIconButton Icon="@Icons.Material.Outlined.Notifications"
                               Color="Color.Default"/>
            </MudBadge>
        </MudTooltip>

        <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Dense="true">
            <ActivatorContent Context="userMenu">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="px-2 py-1" Style="cursor: pointer; border-radius: 999px;">
                    <MudAvatar Size="Size.Small" Color="Color.Primary">AM</MudAvatar>
                    <div class="d-none d-md-flex flex-column" style="line-height:1.1;">
                        <MudText Typo="Typo.body2" Style="font-weight: 600;">Anna Müller</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Tertiary" Style="font-size: 0.72rem;">Anbieter · Pro</MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowDown" Size="Size.Small" Color="Color.Default"/>
                </MudStack>
            </ActivatorContent>
            <ChildContent>
                <MudMenuItem Icon="@Icons.Material.Outlined.AccountCircle" Href="/einstellungen/profil">Mein Profil</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Outlined.Business" Href="/einstellungen/organisation">Organisation</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Outlined.CreditCard" Href="/abo">Abo &amp; Abrechnung</MudMenuItem>
                <MudDivider Class="my-1"/>
                <MudMenuItem Icon="@Icons.Material.Outlined.Logout" Href="/Account/Logout">Abmelden</MudMenuItem>
            </ChildContent>
        </MudMenu>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               Elevation="0"
               Variant="DrawerVariant.Responsive"
               Breakpoint="Breakpoint.Md"
               ClipMode="DrawerClipMode.Always">
        <NavMenu/>
    </MudDrawer>

    <MudMainContent Class="pt-16">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-6 px-4 px-md-8">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    Ein Fehler ist aufgetreten.
    <a href="." class="reload">Neu laden</a>
    <span class="dismiss">✕</span>
</div>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode = true;

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private void ToggleTheme() => _isDarkMode = !_isDarkMode;
}
